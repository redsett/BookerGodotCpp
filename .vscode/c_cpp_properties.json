{
  "configurations": [
    {
      "name": "Godot GDExtension",
      "includePath": [
          "${workspaceFolder}/**",
          "${workspaceFolder}/godot-cpp/include",
          "${workspaceFolder}/godot-cpp/gen/include"
      ],
      "defines": [
          "DEBUG_ENABLED",
          "TOOLS_ENABLED"
      ],
      "compilerPath": "${workspaceFolder}\\gcc.exe",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-gcc-x64"
    }
  ],
  "version": 4
}